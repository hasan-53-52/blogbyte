# ============================================
#   BlogByte — Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/blogbyte

# Session Secret (change this to a long random string in production)
SESSION_SECRET=your_super_secret_session_key_change_in_production

# Admin Registration Secret (used when creating admin accounts)
ADMIN_SECRET=your_admin_registration_secret

# App URL (used for SEO / canonical links)
APP_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
